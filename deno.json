{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",

  "imports": {
    "jsr:@chalie/interface-sdk@1": "jsr:@chalie/interface-sdk@1"
  },

  "tasks": {
    "dev": "deno run --allow-net --allow-read --allow-write --allow-env daemon.ts --gateway=http://localhost:3000",

    "compile:linux":   "deno compile --allow-net --allow-read --allow-write --allow-env --target x86_64-unknown-linux-gnu  --output dist/daemon-linux-x64        daemon.ts",
    "compile:mac-x64": "deno compile --allow-net --allow-read --allow-write --allow-env --target x86_64-apple-darwin        --output dist/daemon-mac-x64          daemon.ts",
    "compile:mac-arm": "deno compile --allow-net --allow-read --allow-write --allow-env --target aarch64-apple-darwin        --output dist/daemon-mac-arm64         daemon.ts",
    "compile:windows": "deno compile --allow-net --allow-read --allow-write --allow-env --target x86_64-pc-windows-msvc     --output dist/daemon-windows-x64.exe   daemon.ts",

    "compile:all": "deno task compile:linux && deno task compile:mac-x64 && deno task compile:mac-arm && deno task compile:windows"
  },

  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true
  }
}
